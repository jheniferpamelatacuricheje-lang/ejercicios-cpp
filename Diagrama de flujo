#include <iostream>
using namespace std;

int main() {
    int A, B;
    if (cin >> A >> B) {
        if (A + B == 5) {
            cout << (2 * A) + (B + 3) << "\n";
        } else {
            A -= 1;
            if ((7 * A + B) % 2 == 0) cout << A - B << "\n";
            else cout << A * B << "\n";
        }
    }
    return 0;
}
