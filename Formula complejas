#include <iostream>
using namespace std;

int main() {
    double x, y, z;
    if (cin >> x >> y >> z) {
        double num = ((2 * x + y) / z) * (y * y * y - z);
        double den = ((x + 2 * y + 3 * z) / (z - 2 * y - 3 * x)) + x * x + z * z;
        cout << num / den << "\n";
    }
    return 0;
}
