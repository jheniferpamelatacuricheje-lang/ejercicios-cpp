#include <iostream>
using namespace std;

int main() {
    int N;
    cin >> N;
    int X, Y;
    for (int i = 0; i < N; i++) {
        cin >> X >> Y;

        if (X > 0 && Y > 0) {
            cout << "I";
        }
        else if (X < 0 && Y > 0) {
            cout << "II";
        }
        else if (X < 0 && Y < 0) {
            cout << "III";
        }
        else if (X > 0 && Y < 0) {
            cout << "IV";
        }
        cout << endl;
    }
    return 0;
}
